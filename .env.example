# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Secrets belong in .env only — never commit .env or data/settings.json.

# --- Local development ---
# HOST=127.0.0.1
# PORT=5001

# --- Optional mail defaults (or enter in the web UI each session) ---
# MAIL_PROVIDER=gmail
# EMAIL_ADDRESS=
# APP_PASSWORD=

# Anti-spam limits (adjust conservatively)
# DAILY_LIMIT=50
# DELAY_SECONDS=60
# DELAY_JITTER_SECONDS=30
